{#
  Core History entity — Teradata binding of design/modules/domain.md §3.1.
  Realises the temporal-lifecycle-metadata pattern with a bi-temporal strategy.
  Capabilities: CurrentStateFilter, PointInTimeReconstruction, NaturalKeyLookup,
                RichMetadata. Invariant support: INV-DOMAIN-001,002,004,006,007.

  Template variables:
    database    : Domain database name, e.g. "{{ product }}_Domain"
    entity.name : PascalCase entity name, e.g. "Party"
    entity.lower: lower_snake entity name, e.g. "party"
    entity.natural_key_len : VARCHAR length for the natural key
    entity.table_comment   : business description of the entity
    entity.attributes      : list of business attributes, each:
        { name, type, nullable(bool), comment,
          ref(optional target entity for FK columns) }

  {entity}_id is sourced from {entity}_Keymap on load — NOT generated here — so the
  surrogate is stable across all SCD versions (INV-DOMAIN-003).
#}
CREATE TABLE {{ database }}.{{ entity.name }}_H (
    -- Identity
    {{ entity.lower }}_id        BIGINT NOT NULL,
    {{ entity.lower }}_key       VARCHAR({{ entity.natural_key_len | default(50) }}) NOT NULL,

    -- Bi-temporal validity (point-in-time reconstruction)
    valid_from_dts      TIMESTAMP(6) WITH TIME ZONE NOT NULL,
    valid_to_dts        TIMESTAMP(6) WITH TIME ZONE NOT NULL
                            DEFAULT TIMESTAMP '9999-12-31 23:59:59.999999+00:00',
    transaction_from_dts TIMESTAMP(6) WITH TIME ZONE NOT NULL DEFAULT CURRENT_TIMESTAMP(6),
    transaction_to_dts   TIMESTAMP(6) WITH TIME ZONE NOT NULL
                            DEFAULT TIMESTAMP '9999-12-31 23:59:59.999999+00:00',

    -- State indicators
    is_current          BYTEINT NOT NULL DEFAULT 1,
    is_deleted          BYTEINT NOT NULL DEFAULT 0,

    -- Business attributes (designer supplied)
{%- for a in entity.attributes %}
    {{ a.name }}        {{ a.type }}{% if not a.nullable %} NOT NULL{% endif %}{% if not loop.last %},{% endif %}
{%- endfor %}
)
PRIMARY INDEX ({{ entity.lower }}_id);

COMMENT ON TABLE {{ database }}.{{ entity.name }}_H IS
'{{ entity.table_comment | default(entity.name ~ " history table with temporal tracking - stores all versions of " ~ entity.lower ~ " over time for point-in-time reconstruction") }}';

COMMENT ON COLUMN {{ database }}.{{ entity.name }}_H.{{ entity.lower }}_id IS
'Surrogate key - stable across all versions for the same real-world entity. Sourced from {{ entity.name }}_Keymap; never generated on this table.';

COMMENT ON COLUMN {{ database }}.{{ entity.name }}_H.{{ entity.lower }}_key IS
'Natural business identifier from source system - used for user queries, reports, and external system integration.';

COMMENT ON COLUMN {{ database }}.{{ entity.name }}_H.valid_from_dts IS
'When this version became true in the real world.';
COMMENT ON COLUMN {{ database }}.{{ entity.name }}_H.valid_to_dts IS
'When this version stopped being true in the real world; default 9999-12-31 for the current version.';
COMMENT ON COLUMN {{ database }}.{{ entity.name }}_H.transaction_from_dts IS
'When this version was inserted into the database.';
COMMENT ON COLUMN {{ database }}.{{ entity.name }}_H.transaction_to_dts IS
'When this version was superseded in the database.';
COMMENT ON COLUMN {{ database }}.{{ entity.name }}_H.is_current IS
'Current version indicator - 1 = current active version, 0 = historical superseded version.';
COMMENT ON COLUMN {{ database }}.{{ entity.name }}_H.is_deleted IS
'Soft delete indicator - 1 = logically deleted but retained for audit, 0 = active record.';

{%- for a in entity.attributes %}
COMMENT ON COLUMN {{ database }}.{{ entity.name }}_H.{{ a.name }} IS
'{{ a.comment }}';
{%- endfor %}
