{#
  Relationship (associative) table — Teradata binding of design/modules/domain.md §3.3.
  Capabilities: CurrentStateFilter, RichMetadata. Invariant support: INV-DOMAIN-007.

  Template variables:
    database  : Domain database name
    rel.name  : PascalCase concatenation, e.g. "PartyProduct"
    rel.lower : lower_snake association id stem, e.g. "party_product"
    rel.entity1 : { name, lower }   first entity
    rel.entity2 : { name, lower }   second entity
    rel.attributes : optional list of { name, type, nullable, comment }
#}
CREATE TABLE {{ database }}.{{ rel.name }}_H (
    {{ rel.lower }}_id   BIGINT NOT NULL,
    {{ rel.entity1.lower }}_id     BIGINT NOT NULL,
    {{ rel.entity2.lower }}_id     BIGINT NOT NULL,

    valid_from_dts      TIMESTAMP(6) WITH TIME ZONE NOT NULL,
    valid_to_dts        TIMESTAMP(6) WITH TIME ZONE NOT NULL
                            DEFAULT TIMESTAMP '9999-12-31 23:59:59.999999+00:00',
    is_current          BYTEINT NOT NULL DEFAULT 1,
    is_deleted          BYTEINT NOT NULL DEFAULT 0{% for a in rel.attributes | default([]) %},
    {{ a.name }}        {{ a.type }}{% if not a.nullable %} NOT NULL{% endif %}{% endfor %}
)
PRIMARY INDEX ({{ rel.entity1.lower }}_id);  -- co-locate with first entity

COMMENT ON TABLE {{ database }}.{{ rel.name }}_H IS
'{{ rel.entity1.name }} to {{ rel.entity2.name }} relationship history - associative table with temporal tracking for many-to-many relationships.';

COMMENT ON COLUMN {{ database }}.{{ rel.name }}_H.{{ rel.lower }}_id IS
'Surrogate key for this relationship instance - system generated, unique per association.';
COMMENT ON COLUMN {{ database }}.{{ rel.name }}_H.{{ rel.entity1.lower }}_id IS
'Foreign key to {{ rel.entity1.name }}_H.{{ rel.entity1.lower }}_id - first entity in the relationship.';
COMMENT ON COLUMN {{ database }}.{{ rel.name }}_H.{{ rel.entity2.lower }}_id IS
'Foreign key to {{ rel.entity2.name }}_H.{{ rel.entity2.lower }}_id - second entity in the relationship.';
COMMENT ON COLUMN {{ database }}.{{ rel.name }}_H.is_current IS
'Current version indicator - 1 = current active relationship, 0 = historical.';
COMMENT ON COLUMN {{ database }}.{{ rel.name }}_H.is_deleted IS
'Soft delete indicator - 1 = relationship terminated but retained for audit, 0 = active.';
{%- for a in rel.attributes | default([]) %}
COMMENT ON COLUMN {{ database }}.{{ rel.name }}_H.{{ a.name }} IS
'{{ a.comment }}';
{%- endfor %}
